# Copy to .env and fill in your real values
PORT=4000
MONGODB_URI=mongodb+srv://your-db-user:your-db-password@your-cluster.mongodb.net/eldimind?retryWrites=true&w=majority&appName=your-cluster
FRONTEND_ORIGIN=http://localhost:5173

FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
FIREBASE_PROJECT_ID=your-firebase-project-id
JWT_SECRET=replace-with-a-long-random-secret
SESSION_COOKIE_NAME=eldimind_session
SESSION_COOKIE_SAME_SITE=auto
SESSION_DEFAULT_HOURS=12
SESSION_REMEMBER_ME_DAYS=30

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models

CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# Required in production for photo uploads. If omitted locally, uploads fall back to /uploads/photos.
ML_SERVICE_URL=http://localhost:8000
