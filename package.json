{
  "name": "eldimind-backend",
  "version": "0.1.0",
  "description": "EldiMind backend (Express + TypeScript) - auth & user service (initial scaffold)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:stack": "bash scripts/dev-stack.sh",
    "dev:stack:ps": "pwsh -File scripts/dev-stack.ps1",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "jest --runInBand",
    "lint": "eslint . --ext .ts"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "express-validator": "^6.15.0",
    "firebase-admin": "^11.11.0",
    "helmet": "^6.0.0",
    "mongoose": "^7.0.0",
    "morgan": "^1.10.0",
    "pdfkit": "^0.18.0",
    "socket.io": "^4.8.3",
    "twilio": "^4.6.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.2.5",
    "@types/supertest": "^2.0.12",
    "jest": "^29.5.0",
    "mongodb-memory-server": "^8.11.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.3"
  }
}
